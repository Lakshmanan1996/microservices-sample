/* =========================================================
   Frontend Angular Web App Jenkins Pipeline
 =========================================================*/

pipeline {
    agent none

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        DOCKERHUB_USER = "lakshvar96"
        IMAGE = "frontend"
        SONAR = "frontend" // Jenkins SonarQube server name
    }

    stages {

        // -------------------------------
        stage('Checkout Code') {
            agent { label 'workernode1' }
            steps {
                checkout scm
            }
        }

        // -------------------------------
        stage('Stash Source') {
            agent { label 'workernode1' }
            steps {
                stash includes: '**/*', name: 'source-code'
            }
        }

        // -------------------------------
        stage('SonarQube Analysis') {
            agent { label 'workernode2' }
            steps {
                unstash 'source-code'
                script {
                    def branch = env.BRANCH_NAME ?: "master"
                    withSonarQubeEnv("${SONAR}") {
                        dir('web-application') {
                            // Use Node 18 LTS
                            def nodeHome = tool name: 'NodeJS 18', type: 'jenkins.plugins.nodejs.tools.NodeJSInstallation'
                            def scannerHome = tool name: 'SonarScanner', type: 'hudson.plugins.sonar.SonarRunnerInstallation'

                            sh """
                            export PATH=${nodeHome}/bin:\$PATH
                            npm install
                            # Only run lint if target exists
                            if npm run | grep -q 'lint'; then
                              npm run lint
                            fi

                            ${scannerHome}/bin/sonar-scanner \
                                -Dsonar.projectKey=${IMAGE} \
                                -Dsonar.projectName=${IMAGE} \
                                -Dsonar.projectVersion=${branch} \
                                -Dsonar.sources=src \
                                -Dsonar.exclusions=**/node_modules/**,**/dist/**
                            """
                        }
                    }
                }
            }
        }

        // -------------------------------
        stage('Quality Gate') {
            agent { label 'workernode2' }
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // -------------------------------
        stage('Docker Build') {
            agent { label 'workernode3' }
            steps {
                unstash 'source-code'
                dir('web-application') {
                    sh """
                    docker build -t ${DOCKERHUB_USER}/${IMAGE}:${BUILD_NUMBER} .
                    docker tag ${DOCKERHUB_USER}/${IMAGE}:${BUILD_NUMBER} ${DOCKERHUB_USER}/${IMAGE}:latest
                    """
                }
            }
        }

        // -------------------------------
        stage('Trivy Scan') {
            agent { label 'workernode3' }
            steps {
                sh """
                trivy image --exit-code 1 --severity HIGH,CRITICAL ${DOCKERHUB_USER}/${IMAGE}:${BUILD_NUMBER}
                """
            }
        }

        // -------------------------------
        stage('Push Docker Image') {
            agent { label 'workernode3' }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                }
                sh """
                docker push ${DOCKERHUB_USER}/${IMAGE}:${BUILD_NUMBER}
                docker push ${DOCKERHUB_USER}/${IMAGE}:latest
                """
            }
        }
    }

    post {
        success { echo "✅ Angular Frontend Pipeline SUCCESS" }
        failure { echo "❌ Angular Frontend CI Pipeline FAILED" }
    }
}
